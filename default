# Default server configuration

# An Nginx default server block is the fallback configuration used to process 
# an incoming HTTP request when the requested hostname (found in the HTTP Host header) 
# does not match any explicitly defined server_name in your other configuration files

server {

    server_name _;

    listen 80 default_server;
    listen [::]:80 default_server;
 
    return 444;
}

#Secure server block 
server {

    server_name biglab.usask.ca; # managed by Certbot

    # ───────── STATIC /public — served off disk by nginx, never touches Node ─────────
    # root /srv/data maps e.g. /fonts/x.woff2 -> /srv/data/fonts/x.woff2.

    # The viewer is the only static *document* in /public, so it's the only static
    # thing that needs a CSP. nginx emits it in prod, so nginx stamps the CSP here.
    # Keep byte-identical to VIEWER_CSP in proxy.ts.
    location /supersplat-viewer/ {
        root /srv/data;
        try_files $uri =404;
        add_header Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'wasm-unsafe-eval' blob:; style-src 'self' 'unsafe-inline'; img-src 'self'; font-src 'self'; connect-src 'self'; worker-src 'self' blob:; object-src 'none'; base-uri 'self'; frame-ancestors 'self'" always;
        expires 1h;                       # viewer app changes only on deploy
        add_header Cache-Control "public" always;
    }

    # Heavy splat tiles — immutable per scene, cache hard.
    location /processed-data/ {
        root /srv/data;
        try_files $uri =404;
        expires 7d;
        add_header Cache-Control "public" always;
        access_log off;                   # don't flood the log with hundreds of tiles
    }

    # Self-hosted fonts — immutable.
    location /fonts/ {
        root /srv/data;
        try_files $uri =404;
        expires 30d;
        add_header Cache-Control "public" always;
    }

    # Scene manifest — changes every deploy, must NOT be cached.
    location = /scenes.json {
        root /srv/data;
        add_header Cache-Control "no-store" always;
    }

    # Fallback thumbnail.
    location = /fallbackthumb.jpg {
        root /srv/data;
        expires 7d;
        add_header Cache-Control "public" always;
    }

    # ───────── EVERYTHING ELSE → Node (app pages, /_next/*, Server Actions) ─────────
    # Node stamps the strict per-request nonce CSP itself; nginx must NOT add a CSP
    # here or it would collide with the nonce.
    location / {
        proxy_pass http://localhost:3000;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_cache_bypass $http_upgrade;
        proxy_buffering off;
        proxy_set_header X-Accel-Buffering no;
    }

    listen [::]:443 ssl ipv6only=on; # managed by Certbot
    listen 443 ssl; # managed by Certbot

    ssl_certificate /etc/letsencrypt/live/biglab.usask.ca/fullchain.pem; # managed by Certbot
    ssl_certificate_key /etc/letsencrypt/live/biglab.usask.ca/privkey.pem; # managed by Certbot
    include /etc/letsencrypt/options-ssl-nginx.conf; # managed by Certbot
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem; # managed by Certbot

}

#HTTP redirect
#Listens on port 80 for a HTTP request to biglab.usask.ca
#Returns a 301 to the user which will automatically bounce the user to
#Go through the secure server block (it seems)

server {
    listen 80;
    listen [::]:80;
    server_name biglab.usask.ca; 

    return 301 https://$host$request_uri;
}

